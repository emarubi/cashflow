{
  "name": "@cashflow/backend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev -r tsconfig-paths/register --respawn --transpile-only src/index.ts",
    "build": "tsc && mkdir -p dist/graphql && cp @/graphql/schema.graphql dist/graphql/schema.graphql",
    "start": "node -r ./register-paths.js dist/index.js",
    "test": "jest",
    "test:unit": "jest --testPathPattern=tests/unit",
    "test:integration": "jest --testPathPattern=tests/integration",
    "migrate:create": "db-migrate create --sql-file --migrations-dir src/db/migrations",
    "migrate:up": "db-migrate up --migrations-dir src/db/migrations",
    "migrate:down": "db-migrate down --migrations-dir src/db/migrations",
    "seed": "ts-node src/db/seeds/index.ts"
  },
  "dependencies": {
    "@apollo/server": "^4.11.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.0.0",
    "dataloader": "^2.2.2",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "graphql": "^16.8.1",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.11.0",
    "@types/supertest": "^6.0.2",
    "db-migrate": "^0.11.14",
    "db-migrate-pg": "^1.3.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@auth/(.*)$": "<rootDir>/src/auth/$1",
      "^@graphql/(.*)$": "<rootDir>/@/graphql/$1",
      "^@db/(.*)$": "<rootDir>/src/db/$1",
      "^@queues/(.*)$": "<rootDir>/src/queues/$1",
      "^@cache/(.*)$": "<rootDir>/src/cache/$1"
    }
  }
}
